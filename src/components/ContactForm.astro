---
import { siteConfig } from "../data/site";
const accessKey = import.meta.env.PUBLIC_WEB3FORMS_KEY ?? "";
---
<form class="form" id="contact-form" data-web3-form data-form-type="contact" novalidate>
  <input type="hidden" name="access_key" value={accessKey} />
  <input type="hidden" name="from_name" value={`Website contact — ${siteConfig.companyName}`} />
  <input
    type="checkbox"
    name="botcheck"
    class="hp-field"
    tabindex="-1"
    autocomplete="off"
    aria-hidden="true"
  />

  <div class="form-grid">
    <div class="field">
      <label for="contact-name">Full Name <span class="req">*</span></label>
      <input id="contact-name" name="fullName" type="text" autocomplete="name" minlength="3" required aria-describedby="fullName-error" />
      <span class="field__error" id="fullName-error" aria-live="polite"></span>
    </div>
    <div class="field">
      <label for="contact-phone">Phone <span class="req">*</span></label>
      <input id="contact-phone" name="phone" type="tel" autocomplete="tel" maxlength="20" required aria-describedby="phone-error" />
      <span class="field__error" id="phone-error" aria-live="polite"></span>
    </div>
    <div class="field">
      <label for="contact-email">Email <span class="req">*</span></label>
      <input id="contact-email" name="email" type="email" autocomplete="email" required aria-describedby="email-error" />
      <span class="field__error" id="email-error" aria-live="polite"></span>
    </div>
    <div class="field">
      <label for="contact-subject">Subject <span class="req">*</span></label>
      <input id="contact-subject" name="subject" type="text" minlength="4" required aria-describedby="subject-error" />
      <span class="field__error" id="subject-error" aria-live="polite"></span>
    </div>
    <div class="field field--full">
      <label for="contact-message">Message <span class="req">*</span></label>
      <textarea id="contact-message" name="message" rows="6" minlength="20" required aria-describedby="message-error"></textarea>
      <span class="field__error" id="message-error" aria-live="polite"></span>
    </div>
  </div>
  <button class="btn btn--primary" type="submit">Send Message</button>
  <p class="form-feedback" role="status" aria-live="polite"></p>
</form>

<script>
  import { initForms } from "../scripts/forms";
  initForms();
</script>
