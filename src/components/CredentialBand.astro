---
import { credentialBadges } from "../data/credentials";

interface Props {
  light?: boolean;
}
const { light = false } = Astro.props;
---
<div class="credential-band" role="list" aria-label="Company credentials">
  {
    credentialBadges.map((b) => (
      <span class={`credential-chip ${light ? "credential-chip--light" : ""}`} role="listitem">
        <span class="credential-chip__label">{b.label}</span>
        <span class="credential-chip__value">{b.value}</span>
      </span>
    ))
  }
</div>
