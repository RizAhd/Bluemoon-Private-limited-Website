---
import { siteConfig } from "../data/site";
import { navigation } from "../data/navigation";
import { services } from "../data/services";
import { credentials } from "../data/credentials";

const year = new Date().getFullYear();
const footerServices = services.slice(0, 5);
---

<footer class="site-footer">
  <div class="container footer-grid">
    <div class="footer-brand">
      <a class="brand" href="/" aria-label={`${siteConfig.companyName} home`}>
        <img src="/logo-mark.svg" alt="" width="40" height="40" />
        <span class="brand__text">
          <strong>{siteConfig.brandName}</strong>
          <small>{siteConfig.brandMeta}</small>
        </span>
      </a>
      <p>{siteConfig.description}</p>
      <p class="footer-cred">
        CIDA Reg. {credentials.cidaReg} · Business Reg. {credentials.businessReg}
      </p>
    </div>

    <div class="footer-col">
      <h3>Explore</h3>
      <ul>
        {navigation.map((item) => <li><a href={item.href}>{item.label}</a></li>)}
      </ul>
    </div>

    <div class="footer-col">
      <h3>Services</h3>
      <ul>
        {footerServices.map((s) => <li><a href={`/services#${s.slug}`}>{s.title}</a></li>)}
      </ul>
    </div>

    <div class="footer-col">
      <h3>Contact</h3>
      <ul class="footer-contact">
        <li><a href={`tel:${siteConfig.phoneHref}`}>{siteConfig.phoneDisplay}</a></li>
        <li><a href={`mailto:${siteConfig.email}`}>{siteConfig.email}</a></li>
        <li><a href={siteConfig.whatsapp} target="_blank" rel="noopener">WhatsApp</a></li>
        <li>{siteConfig.addressInline}</li>
        <li>{siteConfig.hours}</li>
      </ul>
    </div>
  </div>
  <div class="container footer-bottom">
    <p>&copy; {year} {siteConfig.companyName}. All rights reserved.</p>
    <p>Welimada · Badulla · Uva Province, Sri Lanka</p>
  </div>
</footer>

<style>
  .site-footer {
    background: linear-gradient(180deg, var(--color-navy-900), var(--color-navy-950));
    color: rgba(255, 255, 255, 0.72);
    padding-top: clamp(3rem, 6vw, 4.5rem);
  }
  .footer-grid {
    display: grid;
    grid-template-columns: 1.6fr 1fr 1fr 1.2fr;
    gap: 2rem;
    padding-bottom: 2.5rem;
  }
  .footer-brand .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
    text-decoration: none;
    margin-bottom: 1rem;
  }
  .footer-brand .brand__text {
    display: flex;
    flex-direction: column;
    line-height: 1.1;
  }
  .footer-brand .brand__text strong {
    font-family: var(--font-display);
    font-size: 1.3rem;
    color: var(--color-white);
  }
  .footer-brand .brand__text small {
    font-size: 0.66rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-gold-400);
  }
  .footer-brand p {
    font-size: 0.9rem;
    max-width: 38ch;
  }
  .footer-cred {
    color: var(--color-gold-400);
    font-weight: 600;
    font-size: 0.82rem !important;
  }
  .footer-col h3 {
    color: var(--color-white);
    font-family: var(--font-body);
    font-size: 0.75rem;
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    margin-bottom: 1rem;
  }
  .footer-col ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.55rem;
    font-size: 0.9rem;
  }
  .footer-col a {
    text-decoration: none;
    color: rgba(255, 255, 255, 0.72);
    transition: color var(--transition);
  }
  .footer-col a:hover {
    color: var(--color-gold-400);
  }
  .footer-bottom {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
    padding-block: 1.5rem;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    font-size: 0.82rem;
    color: rgba(255, 255, 255, 0.55);
  }
  .footer-bottom p {
    margin: 0;
  }
  @media (max-width: 1080px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
    }
  }
  @media (max-width: 620px) {
    .footer-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
