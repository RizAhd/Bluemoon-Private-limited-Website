---
// Accessible gallery lightbox shell. Behaviour wired in scripts/lightbox.ts.
---
<div class="lightbox" id="gallery-lightbox" aria-hidden="true">
  <div class="lightbox__overlay" data-lightbox-close></div>
  <div class="lightbox__dialog" role="dialog" aria-modal="true" aria-labelledby="lightbox-title">
    <button class="lightbox__close" type="button" aria-label="Close preview" data-lightbox-close>
      &times;
    </button>
    <img id="lightbox-image" src="" alt="" />
    <div class="lightbox__meta">
      <h2 id="lightbox-title"></h2>
      <p id="lightbox-category"></p>
    </div>
  </div>
</div>
