---
import { Image } from "astro:assets";
import type { Project } from "../data/types";

interface Props {
  project: Project;
}
const { project } = Astro.props;
const statusLabel = project.status.charAt(0).toUpperCase() + project.status.slice(1);
---
<article class="project-card" data-tags={project.tags.join(" ")}>
  <div class="project-card__image">
    <Image
      src={project.cover}
      alt={project.alt}
      widths={[400, 700, 900]}
      sizes="(max-width: 620px) 100vw, (max-width: 1080px) 50vw, 33vw"
      loading="lazy"
    />
  </div>
  <div class="project-card__content">
    <div class="project-card__meta">
      <span class="badge">{project.category}</span>
      <span class={`status-badge status-badge--${project.status}`}>{statusLabel}</span>
      {project.value && <span class="project-card__value">{project.value}</span>}
    </div>
    <h3>{project.title}</h3>
    <p>{project.description}</p>
    <div class="project-card__details">
      <span>{project.client}</span>
      <span>{project.year}</span>
    </div>
  </div>
</article>
