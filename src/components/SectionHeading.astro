---
interface Props {
  eyebrow?: string;
  title: string;
  text?: string;
  index?: string;
  align?: "left" | "center";
}
const { eyebrow, title, text, index, align = "left" } = Astro.props;
---
<div class={`section-heading ${align === "center" ? "section-heading--center" : ""}`} data-reveal>
  <div class="section-heading__top">
    {index && <span class="section-heading__index">{index}</span>}
    {eyebrow && <p class="eyebrow">{eyebrow}</p>}
  </div>
  <h2>{title}</h2>
  {text && <p>{text}</p>}
</div>
