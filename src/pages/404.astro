---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout
  title="Page Not Found | Bluemoon Engineering (Pvt) Ltd"
  description="The page you were looking for could not be found."
  noindex={true}
>
  <section class="section" style="text-align:center">
    <div class="container" style="max-width:52ch">
      <p class="eyebrow">Error 404</p>
      <h1>This page could not be found.</h1>
      <p class="lead" style="margin-inline:auto">
        The page may have moved or no longer exists. Let's get you back on track.
      </p>
      <div style="display:flex;gap:0.9rem;justify-content:center;flex-wrap:wrap;margin-top:1.5rem">
        <a class="btn btn--primary" href="/">Back to Home</a>
        <a class="btn btn--ghost" href="/contact">Contact Us</a>
      </div>
    </div>
  </section>
</BaseLayout>
