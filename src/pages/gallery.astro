---
import { Image } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHeading from "../components/SectionHeading.astro";
import Lightbox from "../components/Lightbox.astro";
import { projects } from "../data/projects";

const galleryItems = projects.flatMap((project) =>
  project.images.map((img) => ({
    img,
    title: project.title,
    category: `${project.category} · ${project.location}`,
    alt: project.alt,
  })),
);
---
<BaseLayout
  title="Gallery | Bluemoon Engineering (Pvt) Ltd"
  description="Photographs of real construction and renovation work by Bluemoon Engineering — school buildings, commercial projects, and finishing works across Uva Province, Sri Lanka."
  page="gallery"
>
  <section class="page-hero">
    <div class="container page-hero__grid">
      <div>
        <p class="eyebrow" data-hero-item>Project Gallery</p>
        <h1 data-hero-item>A closer look at our work on site.</h1>
        <p data-hero-item>
          Photographs from completed and in-progress projects — building work, finishing, and
          renovation across Welimada, Badulla, and Bandarawela.
        </p>
      </div>
      <div class="page-hero__panel surface-card" data-hero-item>
        <p style="margin-bottom:0">Select any image to view it larger.</p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHeading eyebrow="On Site" title="Real photographs from Bluemoon Engineering projects." />
      <div id="gallery-grid" class="gallery-grid" data-stagger>
        {
          galleryItems.map((item) => (
            <button
              class="gallery-card"
              type="button"
              data-gallery-item
              data-img={item.img.src}
              data-title={item.title}
              data-category={item.category}
              data-alt={item.alt}
            >
              <Image
                src={item.img}
                alt={item.alt}
                widths={[400, 700]}
                sizes="(max-width: 620px) 100vw, (max-width: 1080px) 50vw, 33vw"
                loading="lazy"
              />
              <span class="gallery-card__meta">
                <span class="gallery-card__title">{item.title}</span>
                <span>{item.category}</span>
              </span>
            </button>
          ))
        }
      </div>
    </div>
  </section>

  <Lightbox />
</BaseLayout>

<script>
  import { initLightbox } from "../scripts/lightbox";
  initLightbox();
</script>
