---
import { Image } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHeading from "../components/SectionHeading.astro";
import ServiceCard from "../components/ServiceCard.astro";
import ProjectCard from "../components/ProjectCard.astro";
import CtaBand from "../components/CtaBand.astro";
import Icon from "../components/Icon.astro";
import { siteConfig } from "../data/site";
import { services } from "../data/services";
import { featuredProjects } from "../data/projects";
import { stats } from "../data/values";
import { reasons } from "../data/reasons";
import { sectors } from "../data/sectors";
import { contractCount, totalContractMillions, formatLKRCompact } from "../lib/currency";

const featuredServices = services.filter((s) => s.featured);
const [leadProject, ...otherProjects] = featuredProjects;
const heroStats = [
  { n: `${contractCount}`, l: "Contracts delivered" },
  { n: `Rs ${totalContractMillions}M+`, l: "Value of completed works" },
  { n: "C-6 / C-7", l: "CIDA grades" },
  { n: `${siteConfig.established}`, l: "Registered since" },
];
const marquee = [...sectors, ...sectors];
---
<BaseLayout
  title="Bluemoon Engineering (Pvt) Ltd | CIDA-Registered Construction Contractor, Uva Province"
  description="Bluemoon Engineering (Pvt) Ltd is a CIDA-registered building & civil-engineering contractor in Welimada, Badulla, delivering schools, public buildings, roads, drainage, and renovations for government and private clients across Uva Province, Sri Lanka."
  page="home"
>
  <section class="hero">
    <div class="hero__bg" aria-hidden="true"></div>
    <img class="hero__watermark" src="/logo-icon-white.png" alt="" aria-hidden="true" />
    <div class="container">
      <div class="hero__top">
        <p class="eyebrow" data-hero-item>{siteConfig.region}</p>
        <h1 data-hero-item>
          Registered building &amp; civil-engineering contractor for Sri Lanka's <span class="gold-text">hill country</span>.
        </h1>
        <div class="hero__lead-row" data-hero-item>
          <p class="lead">{siteConfig.description}</p>
          <div class="hero__actions">
            <a class="btn btn--primary" href="/quote">Request a Quote</a>
            <a class="btn btn--ghost" href="/projects">View Projects</a>
          </div>
        </div>
      </div>
      <div class="hero__bar" data-hero-item>
        {
          heroStats.map((s) => (
            <div class="hero__bar-item">
              <span class="n">{s.n}</span>
              <span class="l">{s.l}</span>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <div class="marquee" aria-hidden="true">
    <div class="marquee__track">
      {marquee.map((s) => <span>{s}</span>)}
    </div>
  </div>

  <section class="section">
    <div class="container">
      <SectionHeading
        index="01"
        eyebrow="What We Do"
        title="Construction and civil-engineering capability, registered and proven."
        text="From institutional buildings to infrastructure and finishing works, our services are backed by CIDA grading and a real record of delivery."
      />
      <div class="card-grid card-grid--services" data-stagger>
        {featuredServices.map((service) => <ServiceCard service={service} />)}
      </div>
      <p style="margin-top:1.75rem"><a class="btn btn--ghost" href="/services">All Services</a></p>
    </div>
  </section>

  <section class="section section--dark">
    <div class="container">
      <SectionHeading
        index="02"
        eyebrow="Selected Work"
        title="Real projects delivered for government and private clients."
        text="A sample of completed work across schools, commercial buildings, and renovations in Uva Province."
      />
      <article class="feature-project" data-reveal>
        <div class="feature-project__media">
          <Image
            src={leadProject.cover}
            alt={leadProject.alt}
            widths={[600, 900]}
            sizes="(max-width: 1080px) 100vw, 55vw"
          />
        </div>
        <div class="feature-project__body">
          <div class="feature-project__meta">
            <span class="badge">{leadProject.category}</span>
            <span class="status-badge status-badge--completed">Completed</span>
            <span class="project-card__value">{formatLKRCompact(leadProject.valueLKR!)}</span>
          </div>
          <h3 style="font-size:clamp(1.5rem,2.4vw,2.1rem)">{leadProject.title}</h3>
          <p>{leadProject.description}</p>
          <p style="color:var(--color-ink-500);font-size:0.9rem;margin:0">
            {leadProject.client} · {leadProject.location} · {leadProject.year}
          </p>
        </div>
      </article>
      <div class="card-grid card-grid--projects" data-stagger>
        {otherProjects.map((project) => <ProjectCard project={project} />)}
      </div>
      <p style="margin-top:1.75rem"><a class="btn btn--ghost" href="/projects">View All Projects</a></p>
    </div>
  </section>

  <section class="section section--soft">
    <div class="container">
      <SectionHeading
        index="03"
        eyebrow="By The Numbers"
        title="A track record you can verify."
        text="Honest figures drawn directly from our record of completed work."
      />
      <div class="stat-band" data-stagger>
        {
          stats.map((stat) => (
            <article class="stat-card">
              <span class="stat-card__value">
                {stat.prefix}
                <span data-counter={stat.value}>0</span>
                {stat.suffix}
              </span>
              <p class="stat-card__label">{stat.label}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container split-layout split-layout--balanced">
      <div class="split-layout__content" data-reveal>
        <p class="eyebrow">Why Bluemoon</p>
        <h2>A registered, accountable partner you can trust with public and private work.</h2>
        <p>
          We combine CIDA-graded capability with transparent communication, measured planning, and
          finish discipline suited to hill-country sites and government reporting standards.
        </p>
        <a class="btn btn--ghost" href="/why-choose-us">Why Choose Us</a>
      </div>
      <div class="card-grid card-grid--compact" data-stagger>
        {
          reasons.map((reason) => (
            <article class="reason-card">
              <span class="icon-badge"><Icon name={reason.icon} /></span>
              <h3>{reason.title}</h3>
              <p>{reason.description}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <CtaBand />
</BaseLayout>
