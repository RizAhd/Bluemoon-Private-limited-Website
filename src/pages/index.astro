---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHeading from "../components/SectionHeading.astro";
import ServiceCard from "../components/ServiceCard.astro";
import ProjectCard from "../components/ProjectCard.astro";
import CredentialBand from "../components/CredentialBand.astro";
import CtaBand from "../components/CtaBand.astro";
import Icon from "../components/Icon.astro";
import { siteConfig } from "../data/site";
import { services } from "../data/services";
import { featuredProjects } from "../data/projects";
import { stats } from "../data/values";
import { reasons } from "../data/reasons";

const featuredServices = services.filter((s) => s.featured);
const heroStats = [
  { n: "12+", l: "Contracts delivered" },
  { n: "Rs 80M+", l: "Completed works" },
  { n: "C-6 / C-7", l: "CIDA grades" },
  { n: "6", l: "Construction fields" },
];
---
<BaseLayout
  title="Bluemoon Engineering (Pvt) Ltd | CIDA-Registered Construction Contractor, Uva Province"
  description="Bluemoon Engineering (Pvt) Ltd is a CIDA-registered building & civil-engineering contractor in Welimada, Badulla, delivering schools, public buildings, roads, drainage, and renovations for government and private clients across Uva Province, Sri Lanka."
  page="home"
>
  <section class="hero">
    <div class="hero__bg" aria-hidden="true"></div>
    <img class="hero__watermark" src="/logo-icon-white.png" alt="" aria-hidden="true" />
    <div class="container hero-grid">
      <div class="hero__content">
        <p class="eyebrow" data-hero-item>{siteConfig.region}</p>
        <h1 data-hero-item>
          Registered building &amp; civil-engineering contractor for Sri Lanka's <span class="gold-text">hill country</span>.
        </h1>
        <p class="lead" data-hero-item>
          Bluemoon Engineering (Pvt) Ltd delivers schools, public buildings, roads, drainage, and
          renovations for government departments and private clients across Uva Province — with
          disciplined planning, sound method, and accountable delivery.
        </p>
        <div class="hero__actions" data-hero-item>
          <a class="btn btn--primary" href="/quote">Request a Quote</a>
          <a class="btn btn--ghost" href="/projects">View Projects</a>
        </div>
        <div data-hero-item><CredentialBand /></div>
      </div>
      <aside class="hero__panel glass" data-hero-item aria-label="Company highlights">
        <div class="hero__panel-head">
          <img src="/logo-icon-white.png" alt="" width="40" height="40" />
          <span>CIDA Registered · Est. {siteConfig.established}</span>
        </div>
        <div class="hero__stats">
          {
            heroStats.map((s) => (
              <div class="hero__stat">
                <span class="n">{s.n}</span>
                <span class="l">{s.l}</span>
              </div>
            ))
          }
        </div>
      </aside>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHeading
        eyebrow="What We Do"
        title="Construction and civil-engineering capability, registered and proven."
        text="From institutional buildings to infrastructure and finishing works, our services are backed by CIDA grading and a real record of delivery."
      />
      <div class="card-grid card-grid--services" data-stagger>
        {featuredServices.map((service) => <ServiceCard service={service} />)}
      </div>
      <p style="margin-top:1.75rem"><a class="btn btn--ghost" href="/services">All Services</a></p>
    </div>
  </section>

  <section class="section section--dark">
    <div class="container">
      <SectionHeading
        eyebrow="Selected Work"
        title="Real projects delivered for government and private clients."
        text="A sample of completed work across schools, commercial buildings, and renovations in Uva Province."
      />
      <div class="card-grid card-grid--projects" data-stagger>
        {featuredProjects.map((project) => <ProjectCard project={project} />)}
      </div>
      <p style="margin-top:1.75rem"><a class="btn btn--ghost" href="/projects">View All Projects</a></p>
    </div>
  </section>

  <section class="section section--soft">
    <div class="container">
      <div class="stat-band" data-stagger>
        {
          stats.map((stat) => (
            <article class="stat-card">
              <span class="stat-card__value"><span data-counter={stat.value}>0</span>{stat.suffix}</span>
              <p class="stat-card__label">{stat.label}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container split-layout split-layout--balanced">
      <div class="split-layout__content" data-reveal>
        <p class="eyebrow">Why Bluemoon</p>
        <h2>A registered, accountable contractor you can trust with public and private work.</h2>
        <p>
          We combine CIDA-graded capability with transparent communication, measured planning, and
          finish discipline suited to hill-country sites and government reporting standards.
        </p>
        <a class="btn btn--ghost" href="/why-choose-us">Why Choose Us</a>
      </div>
      <div class="card-grid card-grid--compact" data-stagger>
        {
          reasons.map((reason) => (
            <article class="reason-card">
              <span class="icon-badge"><Icon name={reason.icon} /></span>
              <h3>{reason.title}</h3>
              <p>{reason.description}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <CtaBand />
</BaseLayout>
